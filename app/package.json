{
  "name": "bookclub-root",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "install:all": "pnpm install",
    "dev:web": "pnpm --filter ./apps/web dev",
    "mock:start": "pnpm --filter ./apps/web mock:start",
    "codegen": "pnpm --filter ./apps/web codegen"
  },
  "devDependencies": {
    "@playwright/test": "^1.36.0",
    "msw": "^1.3.5"
  }
}
